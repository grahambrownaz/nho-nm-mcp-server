// NHO/NM MCP Server Database Schema
// Manages tenants, subscriptions, usage tracking, and data access

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// TENANT MANAGEMENT
// ============================================================================

model Tenant {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  company     String?
  phone       String?
  status      TenantStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Stripe integration
  stripeCustomerId  String?  @unique

  // Reseller Mode (Path C)
  parentTenantId    String?
  parentTenant      Tenant?  @relation("TenantHierarchy", fields: [parentTenantId], references: [id])
  subTenants        Tenant[] @relation("TenantHierarchy")
  isReseller        Boolean  @default(false)
  wholesalePricing  Json?    // Custom pricing for reseller { pricePerRecord, priceEmailAppend, etc. }

  // Relations
  apiKeys           ApiKey[]
  subscriptions     Subscription[]
  usageRecords      UsageRecord[]
  dataPulls         DataPull[]
  dataSubscriptions DataSubscription[]
  templates         Template[]
  listPurchases     ListPurchase[]
  intentSubscriptions IntentSubscription[]
  intentWebhooks    IntentWebhook[]
  emailConfig       EmailConfig?
  emailCampaigns    EmailCampaign[]
  swotspotConfig      SwotspotConfig?
  swotspotAudits      SwotspotAudit[]
  swotspotCompetitors SwotspotCompetitor[]

  @@index([parentTenantId])
  @@map("tenants")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  PENDING
}

// ============================================================================
// AUTHENTICATION
// ============================================================================

model ApiKey {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String   // e.g., "Production Key", "Development Key"
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions String[] // e.g., ["data:read", "data:write", "subscription:read"]
  isActive    Boolean  @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([tenantId])
  @@map("api_keys")
}

// ============================================================================
// SUBSCRIPTIONS & BILLING
// ============================================================================

model Subscription {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan            SubscriptionPlan
  status          SubscriptionStatus @default(ACTIVE)

  // Stripe integration
  stripeSubscriptionId  String?  @unique

  // Data allowances
  monthlyRecordLimit    Int      @default(1000)
  monthlyEmailAppends   Int      @default(500)
  monthlyPhoneAppends   Int      @default(500)

  // Geographic restrictions (null = all geographies)
  allowedStates         String[] // Empty array = all states
  allowedZipCodes       String[] // Empty array = all zips

  // Database access
  allowedDatabases      DatabaseType[] @default([NHO, NEW_MOVER])

  // Pricing (overrides defaults)
  pricePerRecord        Decimal? @db.Decimal(10, 4)
  priceEmailAppend      Decimal? @db.Decimal(10, 4)
  pricePhoneAppend      Decimal? @db.Decimal(10, 4)
  pricePdfGeneration    Decimal? @db.Decimal(10, 4)

  // Billing
  billingCycleStart     DateTime
  billingCycleEnd       DateTime

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([tenantId])
  @@map("subscriptions")
}

enum SubscriptionPlan {
  STARTER       // Basic access, limited records
  PROFESSIONAL  // More records, all databases
  ENTERPRISE    // Unlimited, custom pricing
  TRIAL         // Free trial period
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  PAUSED
  TRIAL
}

enum DatabaseType {
  NHO         // New Homeowner
  NEW_MOVER   // New Mover
  CONSUMER    // Consumer database
  BUSINESS    // Business database
  INTENT      // Intent/purchase signals
}

// ============================================================================
// USAGE TRACKING
// ============================================================================

model UsageRecord {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // What was used
  usageType   UsageType
  quantity    Int

  // Cost calculation
  unitPrice   Decimal  @db.Decimal(10, 4)
  totalCost   Decimal  @db.Decimal(10, 2)

  // Context
  toolName    String   // e.g., "search_data", "get_sample_data"
  database    DatabaseType?
  geography   Json?    // The geography filter used

  // Billing period
  billingMonth DateTime

  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([billingMonth])
  @@index([usageType])
  @@map("usage_records")
}

enum UsageType {
  DATA_RECORD
  EMAIL_APPEND
  PHONE_APPEND
  PDF_GENERATION
  PRINT_FULFILLMENT
  EMAIL_SEND        // ReachMail email sends
  SAMPLE_DATA       // Usually free
  PREVIEW_COUNT     // Usually free
}

// ============================================================================
// DATA PULLS (Audit Trail)
// ============================================================================

model DataPull {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Request details
  database    DatabaseType
  geography   Json     // { type: "zip", values: ["85001", "85002"] }
  filters     Json?    // Demographic filters

  // Results
  recordCount Int
  includeEmail Boolean @default(false)
  includePhone Boolean @default(false)

  // Status
  status      DataPullStatus @default(COMPLETED)
  errorMessage String?

  // Timestamps
  requestedAt DateTime @default(now())
  completedAt DateTime?

  @@index([tenantId])
  @@index([requestedAt])
  @@map("data_pulls")
}

enum DataPullStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

// ============================================================================
// PRICING CONFIGURATION
// ============================================================================

model PricingTier {
  id            String   @id @default(uuid())
  name          String   // e.g., "Standard", "Volume", "Enterprise"

  // Volume thresholds
  minRecords    Int
  maxRecords    Int?     // null = unlimited

  // Prices per unit
  pricePerRecord      Decimal @db.Decimal(10, 4)
  priceEmailAppend    Decimal @db.Decimal(10, 4)
  pricePhoneAppend    Decimal @db.Decimal(10, 4)
  pricePdfGeneration  Decimal @db.Decimal(10, 4)
  pricePrintPerPiece  Decimal @db.Decimal(10, 4)

  // Effective dates
  effectiveFrom DateTime @default(now())
  effectiveTo   DateTime?

  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("pricing_tiers")
}

// ============================================================================
// DATA SUBSCRIPTIONS (Recurring Data Delivery)
// ============================================================================

model DataSubscription {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Subscription name and client info
  name            String
  clientName      String?   // End client name if reselling
  clientEmail     String?
  clientPhone     String?

  // Data criteria
  database        DatabaseType
  geography       Json      // { type: "zip", values: [...] }
  filters         Json?     // Demographic filters

  // Delivery schedule
  frequency       DeliveryFrequency
  nextDeliveryAt  DateTime
  lastDeliveryAt  DateTime?

  // Template and fulfillment
  templateId      String?
  template        Template? @relation(fields: [templateId], references: [id])
  fulfillmentMethod FulfillmentMethod @default(DOWNLOAD)
  fulfillmentConfig Json?   // e.g., { printer_id, mail_class, return_address }

  // Sync/integration channels
  syncChannels    Json?     // e.g., [{ type: "webhook", url: "..." }, { type: "email", address: "..." }]

  // Status
  status          DataSubscriptionStatus @default(ACTIVE)
  pausedAt        DateTime?
  cancelledAt     DateTime?

  // Stats
  totalDeliveries Int      @default(0)
  totalRecords    Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  deliveries      Delivery[]

  @@index([tenantId])
  @@index([status])
  @@index([nextDeliveryAt])
  @@map("data_subscriptions")
}

enum DeliveryFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum FulfillmentMethod {
  DOWNLOAD      // PDF/CSV download
  EMAIL         // Email delivery
  PRINT_MAIL    // Print and mail postcards
  WEBHOOK       // Send to webhook
  FTP           // Upload to FTP
}

enum DataSubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  COMPLETED
}

// ============================================================================
// DELIVERIES (Delivery History)
// ============================================================================

model Delivery {
  id                  String   @id @default(uuid())
  dataSubscriptionId  String
  dataSubscription    DataSubscription @relation(fields: [dataSubscriptionId], references: [id], onDelete: Cascade)
  tenantId            String

  // Delivery details
  recordCount         Int
  newRecordsCount     Int      // Records not seen in previous deliveries
  duplicatesRemoved   Int      @default(0)

  // Files generated
  dataFileUrl         String?  // CSV/JSON file URL
  pdfFileUrl          String?  // PDF file URL (if generated)

  // Fulfillment status
  fulfillmentStatus   FulfillmentStatus @default(PENDING)
  fulfillmentDetails  Json?    // e.g., { tracking_number, mail_date }

  // Costs
  dataCost            Decimal  @db.Decimal(10, 2)
  pdfCost             Decimal  @db.Decimal(10, 2) @default(0)
  fulfillmentCost     Decimal  @db.Decimal(10, 2) @default(0)
  totalCost           Decimal  @db.Decimal(10, 2)

  // Timestamps
  scheduledAt         DateTime
  startedAt           DateTime?
  completedAt         DateTime?

  // Status
  status              DeliveryStatus @default(PENDING)
  errorMessage        String?

  createdAt           DateTime @default(now())

  @@index([dataSubscriptionId])
  @@index([tenantId])
  @@index([scheduledAt])
  @@index([status])
  @@map("deliveries")
}

enum DeliveryStatus {
  PENDING
  PROCESSING
  GENERATING_PDF
  FULFILLING
  COMPLETED
  FAILED
}

enum FulfillmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  NOT_APPLICABLE
}

// ============================================================================
// TEMPLATES (Postcard/Letter Templates)
// ============================================================================

model Template {
  id              String   @id @default(uuid())
  tenantId        String?  // null = system template
  tenant          Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Template info
  name            String
  description     String?
  category        TemplateCategory
  size            PostcardSize

  // Content
  htmlFront       String   @db.Text
  htmlBack        String?  @db.Text
  cssStyles       String?  @db.Text

  // Merge fields detected
  mergeFields     String[] // e.g., ["first_name", "last_name", "address"]

  // Preview
  thumbnailUrl    String?
  previewPdfUrl   String?

  // Visibility
  isPublic        Boolean  @default(false)  // Available to all tenants
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  dataSubscriptions DataSubscription[]

  @@index([tenantId])
  @@index([category])
  @@index([isPublic])
  @@map("templates")
}

enum TemplateCategory {
  REALTOR
  HVAC
  INSURANCE
  LANDSCAPING
  HOME_SERVICES
  RETAIL
  GENERAL
  CUSTOM
  EMAIL       // Email templates
}

enum PostcardSize {
  SIZE_4X6    // 4" x 6"
  SIZE_6X9    // 6" x 9"
  SIZE_6X11   // 6" x 11"
}

// ============================================================================
// DELIVERY CONFIGURATION
// ============================================================================

model DeliveryConfig {
  id              String   @id @default(uuid())
  tenantId        String

  // Configuration name
  name            String
  isDefault       Boolean  @default(false)

  // Delivery method
  method          DeliveryMethod

  // SFTP configuration (encrypted)
  sftpHost        String?
  sftpPort        Int?     @default(22)
  sftpUsername    String?
  sftpPassword    String?  // Encrypted
  sftpPrivateKey  String?  @db.Text // Encrypted
  sftpFolderPath  String?

  // JDF configuration
  includeJdf      Boolean  @default(false)
  jdfPreset       String?  // e.g., "4x6_100lb_gloss_fc"

  // Email configuration
  emailAddress    String?

  // Webhook configuration
  webhookUrl      String?
  webhookHeaders  Json?

  // Cloud storage configuration
  cloudProvider   String?  // s3, gcs, azure
  cloudBucket     String?
  cloudPath       String?
  cloudCredentials String? @db.Text // Encrypted

  // Print API configuration
  printApiProvider  String?   // 'reminder_media', 'lob', 'stannp', 'postgrid'
  printApiKey       String?   @db.Text // Encrypted
  printApiSettings  Json?     // Provider-specific settings

  // Connection status
  lastTestAt      DateTime?
  lastTestSuccess Boolean?
  lastTestError   String?

  // Status
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([method])
  @@map("delivery_configs")
}

enum DeliveryMethod {
  SFTP_HOT_FOLDER
  PRINT_API
  EMAIL
  WEBHOOK
  CLOUD_STORAGE
}

// ============================================================================
// DELIVERY RECORDS (Individual Records Delivered - for deduplication)
// ============================================================================

model DeliveryRecord {
  id              String   @id @default(uuid())
  deliveryId      String
  tenantId        String
  subscriptionId  String

  // Record identification (for deduplication)
  recordHash      String   // Hash of normalized address + last_name

  // Original record data
  firstName       String?
  lastName        String?
  address         String
  city            String
  state           String
  zip             String

  // Source data
  database        DatabaseType
  moveDate        DateTime?

  // Delivery timestamp
  deliveredAt     DateTime @default(now())

  @@index([tenantId, recordHash])
  @@index([subscriptionId, recordHash])
  @@index([deliveredAt])
  @@map("delivery_records")
}

// ============================================================================
// LIST PURCHASES (One-time data purchases)
// ============================================================================

model ListPurchase {
  id                    String   @id @default(uuid())
  tenantId              String
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Query criteria
  database              String
  geography             Json
  filters               Json?

  // Record counts
  recordCount           Int
  withEmail             Int      @default(0)
  withPhone             Int      @default(0)

  // Pricing
  baseAmount            Decimal  @db.Decimal(10, 2)
  appendAmount          Decimal  @default(0) @db.Decimal(10, 2)
  discountPercent       Int      @default(0)
  totalAmount           Decimal  @db.Decimal(10, 2)

  // Stripe payment
  stripePaymentLinkId   String?
  stripePaymentIntentId String?
  stripeReceiptUrl      String?
  paymentStatus         PaymentStatus @default(PENDING)

  // Export configuration
  exportFormat          String
  deliveryMethod        String
  deliveryConfig        Json?

  // Download
  downloadUrl           String?
  downloadExpires       DateTime?
  deliveredAt           DateTime?

  // Quote validity
  quoteValidUntil       DateTime?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  exports               ExportFile[]

  @@index([tenantId])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("list_purchases")
}

enum PaymentStatus {
  PENDING
  AWAITING_PAYMENT
  PROCESSING
  COMPLETED
  FAILED
  EXPIRED
  REFUNDED
}

// ============================================================================
// EXPORT FILES (Generated data exports)
// ============================================================================

model ExportFile {
  id                String   @id @default(uuid())
  tenantId          String

  // Source information
  sourceType        String   // 'list_purchase', 'delivery', 'subscription', 'query'
  sourceId          String

  // File details
  format            String   // 'csv', 'excel', 'json'
  s3Key             String
  fileSizeBytes     Int
  recordCount       Int
  columns           Json?    // Array of column names included

  // Download access
  downloadUrl       String?
  downloadExpires   DateTime?
  downloadCount     Int      @default(0)

  createdAt         DateTime @default(now())

  // Relations
  listPurchase      ListPurchase? @relation(fields: [listPurchaseId], references: [id])
  listPurchaseId    String?

  @@index([tenantId])
  @@index([sourceType, sourceId])
  @@index([createdAt])
  @@map("export_files")
}

// ============================================================================
// INTENT DATA (Purchase Intent Signals - Subscription Only)
// ============================================================================

model IntentCategory {
  id              String   @id @default(uuid())

  // Category identification
  code            String   @unique  // e.g., "auto_purchase", "home_improvement"
  name            String            // e.g., "Auto Purchase Intent"
  description     String?

  // Parent category (for hierarchy)
  parentId        String?
  parent          IntentCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children        IntentCategory[] @relation("CategoryHierarchy")

  // Pricing (subscription only)
  monthlyBasePrice    Decimal  @db.Decimal(10, 2)  // Base monthly subscription price
  pricePerSignal      Decimal  @db.Decimal(10, 4)  // Price per intent signal

  // Signal volume estimates
  avgMonthlySignals   Int      @default(0)

  // Data fields available
  availableFields     String[] // e.g., ["email", "phone", "address", "intent_score"]

  // Status
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  subscriptions       IntentSubscription[]

  @@index([parentId])
  @@index([isActive])
  @@map("intent_categories")
}

model IntentSubscription {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Subscription name
  name            String

  // Intent categories subscribed to
  categoryIds     String[]
  categories      IntentCategory[]

  // Geographic targeting
  geography       Json?     // { type: "state", values: ["CA", "TX"] }

  // Signal filters
  minIntentScore  Int?      // Minimum intent score (1-100)
  maxAgeHours     Int?      // Maximum signal age in hours

  // Delivery configuration
  deliveryMethod  IntentDeliveryMethod @default(WEBHOOK)
  webhookId       String?
  webhook         IntentWebhook? @relation(fields: [webhookId], references: [id])

  // Batch delivery settings (for non-realtime)
  batchFrequency  BatchFrequency?
  nextBatchAt     DateTime?

  // Stripe subscription
  stripeSubscriptionId  String?  @unique

  // Monthly billing
  monthlyPrice    Decimal  @db.Decimal(10, 2)
  signalCap       Int?     // Max signals per month (null = unlimited)
  signalsThisMonth Int     @default(0)

  // Status
  status          IntentSubscriptionStatus @default(ACTIVE)
  pausedAt        DateTime?
  cancelledAt     DateTime?

  // Stats
  totalSignalsReceived  Int @default(0)
  totalDeliveries       Int @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  deliveries      IntentDelivery[]

  @@index([tenantId])
  @@index([status])
  @@index([nextBatchAt])
  @@map("intent_subscriptions")
}

enum IntentDeliveryMethod {
  WEBHOOK         // Real-time push to webhook
  BATCH_EMAIL     // Batch delivery via email
  BATCH_SFTP      // Batch delivery via SFTP
  API_POLL        // Customer polls the API
}

enum BatchFrequency {
  HOURLY
  EVERY_4_HOURS
  DAILY
  WEEKLY
}

enum IntentSubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  SUSPENDED       // Payment issue
}

model IntentWebhook {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Webhook configuration
  name            String
  url             String
  secret          String?  // For signature verification

  // Headers to include
  headers         Json?    // { "Authorization": "Bearer xxx" }

  // Retry configuration
  retryAttempts   Int      @default(3)
  retryDelayMs    Int      @default(1000)

  // Filtering
  minIntentScore  Int?     // Only send signals above this score
  categoryFilter  String[] // Only send specific categories

  // Status tracking
  isActive        Boolean  @default(true)
  lastDeliveryAt  DateTime?
  lastSuccessAt   DateTime?
  lastFailureAt   DateTime?
  lastErrorMessage String?
  consecutiveFailures Int  @default(0)

  // Test tracking
  lastTestAt      DateTime?
  lastTestSuccess Boolean?
  lastTestError   String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  subscriptions   IntentSubscription[]
  deliveries      IntentDelivery[]

  @@index([tenantId])
  @@index([isActive])
  @@map("intent_webhooks")
}

model IntentDelivery {
  id                  String   @id @default(uuid())
  subscriptionId      String
  subscription        IntentSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  tenantId            String

  // Webhook used (if applicable)
  webhookId           String?
  webhook             IntentWebhook? @relation(fields: [webhookId], references: [id])

  // Delivery type
  deliveryType        IntentDeliveryType

  // Content
  signalCount         Int
  payload             Json?    // The actual signals delivered

  // Status
  status              IntentDeliveryStatus @default(PENDING)
  attemptCount        Int      @default(0)
  lastAttemptAt       DateTime?
  errorMessage        String?

  // Response tracking (for webhooks)
  responseStatusCode  Int?
  responseTimeMs      Int?

  // Timestamps
  scheduledAt         DateTime?
  deliveredAt         DateTime?
  createdAt           DateTime @default(now())

  @@index([subscriptionId])
  @@index([tenantId])
  @@index([status])
  @@index([scheduledAt])
  @@map("intent_deliveries")
}

enum IntentDeliveryType {
  REALTIME_WEBHOOK    // Immediate push on signal receipt
  BATCH_WEBHOOK       // Scheduled batch to webhook
  BATCH_EMAIL         // Scheduled batch via email
  BATCH_SFTP          // Scheduled batch via SFTP
  API_RESPONSE        // Returned via API call
}

enum IntentDeliveryStatus {
  PENDING
  DELIVERING
  DELIVERED
  FAILED
  RETRYING
}

// ============================================================================
// EMAIL CAMPAIGNS (ReachMail Integration)
// ============================================================================

model EmailConfig {
  id                  String   @id @default(uuid())
  tenantId            String   @unique
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // ReachMail credentials (encrypted)
  reachmailToken      String   @db.Text  // Encrypted with AES-256-GCM
  reachmailAccountId  String?            // Retrieved from API on setup

  // Default sending settings
  defaultFromAddress  String
  defaultReplyTo      String?
  physicalAddress     String             // CAN-SPAM required

  // Domain authentication
  dkimDomain          String?
  isVerified          Boolean  @default(false)

  // Connection status
  lastTestAt          DateTime?
  lastTestSuccess     Boolean?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("email_configs")
}

model EmailCampaign {
  id                    String   @id @default(uuid())
  tenantId              String
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Campaign details
  name                  String
  subject               String
  fromAddress           String
  replyTo               String?
  htmlBody              String?  @db.Text

  // ReachMail IDs
  reachmailCampaignId   String?
  reachmailMailingId    String?
  reachmailListId       String?

  // Recipient tracking
  recipientCount        Int      @default(0)

  // Status
  status                EmailCampaignStatus @default(DRAFT)
  scheduledAt           DateTime?
  sentAt                DateTime?

  // Analytics (cached from ReachMail)
  sent                  Int      @default(0)
  delivered             Int      @default(0)
  opens                 Int      @default(0)
  uniqueOpens           Int      @default(0)
  clicks                Int      @default(0)
  uniqueClicks          Int      @default(0)
  bounces               Int      @default(0)
  optOuts               Int      @default(0)
  lastStatsUpdate       DateTime?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@map("email_campaigns")
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
  CANCELLED
  FAILED
}

// ============================================================================
// SWOTSPOT.AI - LOCAL BUSINESS AUDIT
// ============================================================================

model SwotspotConfig {
  id                String   @id @default(uuid())
  tenantId          String   @unique
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  apiKey            String   @db.Text    // Encrypted with AES-256-GCM
  accountId         String?              // From SWOTSPOT API

  lastTestAt        DateTime?
  lastTestSuccess   Boolean?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("swotspot_configs")
}

model SwotspotAudit {
  id                String   @id @default(uuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  businessName      String
  address           String
  city              String
  state             String
  zip               String?
  industry          String?

  externalAuditId   String?              // SWOTSPOT API ID
  overallScore      Int?
  reportData        Json?    @db.JsonB   // Full cached SWOT report

  status            SwotspotAuditStatus @default(PENDING)
  completedAt       DateTime?

  // Relations
  competitors       SwotspotCompetitor[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
  @@map("swotspot_audits")
}

model SwotspotCompetitor {
  id                 String   @id @default(uuid())
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  auditId            String
  audit              SwotspotAudit @relation(fields: [auditId], references: [id])

  businessName       String
  location           String
  externalTrackingId String?
  lastReportData     Json?    @db.JsonB
  isActive           Boolean  @default(true)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([tenantId])
  @@index([auditId])
  @@map("swotspot_competitors")
}

enum SwotspotAuditStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
