# Database
DATABASE_URL="postgresql://user:password@localhost:5432/nho_nm_mcp?schema=public"

# LeadsPlease API
LEADSPLEASE_API_KEY="your-leadsplease-api-key"
LEADSPLEASE_API_URL="https://api.leadsplease.com/v1"

# Server Configuration
MCP_SERVER_NAME="nho-nm-mcp-server"
MCP_SERVER_VERSION="1.0.0"
NODE_ENV="development"

# Authentication
# API keys are stored in the database per tenant
# This is the master admin key for server management
ADMIN_API_KEY="your-admin-api-key"

# Logging
LOG_LEVEL="info"

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE="60"

# Pricing (can be overridden per tenant)
DEFAULT_PRICE_PER_RECORD="0.05"
DEFAULT_PRICE_EMAIL_APPEND="0.02"
DEFAULT_PRICE_PHONE_APPEND="0.03"
DEFAULT_PRICE_PDF_GENERATION="0.10"
