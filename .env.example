# Database
DATABASE_URL="postgresql://user:password@localhost:5432/nho_nm_mcp?schema=public"

# LeadsPlease API
LEADSPLEASE_API_KEY="your-leadsplease-api-key"
LEADSPLEASE_API_URL="https://api.leadsplease.com/v1"

# Server Configuration
MCP_SERVER_NAME="nho-nm-mcp-server"
MCP_SERVER_VERSION="1.0.0"
NODE_ENV="development"

# Authentication
# API keys are stored in the database per tenant
# This is the master admin key for server management
ADMIN_API_KEY="your-admin-api-key"

# Logging
LOG_LEVEL="info"

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE="60"

# Pricing (can be overridden per tenant)
DEFAULT_PRICE_PER_RECORD="0.05"
DEFAULT_PRICE_EMAIL_APPEND="0.02"
DEFAULT_PRICE_PHONE_APPEND="0.03"
DEFAULT_PRICE_PDF_GENERATION="0.10"

# ==============================================================================
# PRINT API PROVIDERS
# Configure the print API providers you want to use.
# Only configure the providers you need - unused providers can be left blank.
# ==============================================================================

# Default provider to use when not specified
PRINT_API_DEFAULT_PROVIDER="reminder_media"

# ReminderMedia (Primary provider)
REMINDER_MEDIA_API_KEY="your-reminder-media-api-key"
REMINDER_MEDIA_API_URL="https://api.remindermedia.com/v1"
REMINDER_MEDIA_WEBHOOK_SECRET=""

# LOB (Alternative provider - stub implementation)
# LOB_API_KEY="your-lob-api-key"
# LOB_API_URL="https://api.lob.com/v1"

# Stannp (Alternative provider - stub implementation)
# STANNP_API_KEY="your-stannp-api-key"
# STANNP_API_URL="https://us.stannp.com/api/v1"

# PostGrid (Alternative provider - stub implementation)
# POSTGRID_API_KEY="your-postgrid-api-key"
# POSTGRID_API_URL="https://api.postgrid.com/print-mail/v1"

# ==============================================================================
# REST API
# ==============================================================================
ENABLE_REST_API="true"
REST_API_PORT="3000"

# ==============================================================================
# MCP SERVER
# ==============================================================================
ENABLE_MCP_SERVER="true"

# ==============================================================================
# SCHEDULER
# ==============================================================================
ENABLE_SCHEDULER="true"
SCHEDULER_TIMEZONE="America/New_York"
SCHEDULER_HOUR="6"

# ==============================================================================
# ENCRYPTION
# ==============================================================================
# Key for encrypting sensitive data (API keys, passwords, etc.)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-32-byte-hex-encryption-key"

# ==============================================================================
# STRIPE BILLING (Week 4)
# ==============================================================================
# Stripe API keys - get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"

# Stripe webhook secret - get from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# Stripe Price IDs - create these in your Stripe dashboard
# Metered prices (usage-based billing)
STRIPE_PRICE_DATA_RECORD="price_data_record"
STRIPE_PRICE_EMAIL_APPEND="price_email_append"
STRIPE_PRICE_PHONE_APPEND="price_phone_append"
STRIPE_PRICE_PDF_GENERATION="price_pdf_generation"
STRIPE_PRICE_PRINT_4X6="price_print_4x6"
STRIPE_PRICE_PRINT_6X9="price_print_6x9"
STRIPE_PRICE_PRINT_6X11="price_print_6x11"

# Platform subscription prices (fixed monthly)
STRIPE_PRICE_PLATFORM_STARTER="price_platform_starter"
STRIPE_PRICE_PLATFORM_GROWTH="price_platform_growth"
STRIPE_PRICE_PLATFORM_PRO="price_platform_pro"

# Checkout success/cancel URLs
STRIPE_CHECKOUT_SUCCESS_URL="https://yourdomain.com/billing/success"
STRIPE_CHECKOUT_CANCEL_URL="https://yourdomain.com/billing/cancel"
